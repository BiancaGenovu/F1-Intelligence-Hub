@app.post("/duel", tags=["Analiză Duel"])
def duel_pilots(data: dict):
    nume_tu = data.get('pilot_tu', '')
    nume_rival = data.get('pilot_rival', '')
    circuit_nume = data.get('circuit', '')

    abbr_tu, circuit_fastf1 = traduce_input(nume_tu, circuit_nume)
    abbr_rival, _ = traduce_input(nume_rival, circuit_nume)

    # Filtrăm datele din Excel pentru cei doi piloți pe acest circuit
    df_cir = df_toate[df_toate['CircuitName'] == circuit_fastf1]
    df_tu = df_cir[df_cir['Abbreviation'] == abbr_tu]
    df_rival = df_cir[df_cir['Abbreviation'] == abbr_rival]

    # Funcție ajutătoare pentru a lua timpii mediani (în milisecunde)
    def get_ms(df_sub, col, default_ms):
        val = df_sub[col].median()
        if pd.isna(val): return default_ms
        return int(val * 1000)

    # Extragem timpii
    t1 = {
        "lapTimeMs": get_ms(df_tu, 'BestQ_sec', 85000),
        "sector1Ms": get_ms(df_tu, 'Sector1Q_sec', 28000),
        "sector2Ms": get_ms(df_tu, 'Sector2Q_sec', 32000),
        "sector3Ms": get_ms(df_tu, 'Sector3Q_sec', 25000),
    }
    t2 = {
        "lapTimeMs": get_ms(df_rival, 'BestQ_sec', 85500),
        "sector1Ms": get_ms(df_rival, 'Sector1Q_sec', 28200),
        "sector2Ms": get_ms(df_rival, 'Sector2Q_sec', 32100),
        "sector3Ms": get_ms(df_rival, 'Sector3Q_sec', 25200),
    }

    # Determinăm câștigătorul
    winner = "you" if t1["lapTimeMs"] < t2["lapTimeMs"] else ("rival" if t2["lapTimeMs"] < t1["lapTimeMs"] else "tie")
    time_diff = t1["lapTimeMs"] - t2["lapTimeMs"]

    def s_comp(s1, s2):
        swin = "you" if s1 < s2 else ("rival" if s2 < s1 else "tie")
        sdiff = s1 - s2
        return {"you": s1, "rival": s2, "diff": sdiff, "winner": swin}

    sec_comp = {
        "sector1": s_comp(t1["sector1Ms"], t2["sector1Ms"]),
        "sector2": s_comp(t1["sector2Ms"], t2["sector2Ms"]),
        "sector3": s_comp(t1["sector3Ms"], t2["sector3Ms"]),
    }

    # Generăm insight-ul cu LLaMA
    nume_castigator = nume_tu if winner == "you" else nume_rival
    prompt = (
        f"Ești un expert în telemetrie F1. Comentează acest duel virtual: {nume_tu} vs {nume_rival} la {circuit_nume}. "
        f"Cel mai bun timp i-a aparținut lui {nume_castigator}. Diferența a fost de {abs(time_diff)/1000.0} secunde. "
        f"Scrie exact un paragraf (maxim 3 propoziții) în română, foarte tehnic și entuziast, ca la TV. Nu repeta cerința."
    )
    
    try:
        response = ollama.generate(model="llama3.1", prompt=prompt, options={'temperature': 0.6})
        insights = response['response'].strip()
    except Exception as e:
        insights = "Analiza AI nu este disponibilă (server LLM offline)."

    return {
        "winner": winner,
        "timeDiff": time_diff,
        "insights": insights,
        "myTime": t1,
        "rivalTime": t2,
        "sectorComparison": sec_comp
    }

