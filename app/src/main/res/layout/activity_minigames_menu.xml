<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810">

    <View
        android:id="@+id/speedLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/speedLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ── HEADER ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.AppCompat.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="← ÎNAPOI"
                    android:textColor="#7070A0"
                    android:textSize="11sp"
                    android:background="@drawable/bg_logout_btn"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MINIJOCURI"
                    android:textColor="#E10600"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:shadowColor="#FF4D2E"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="8"/>

                <View android:layout_width="80dp" android:layout_height="38dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/bg_speed_line"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Antrenează-te ca un pilot F1 real"
                android:textColor="#60607A"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:layout_marginBottom="28dp"/>

            <!-- ── CARD: CIRCUIT QUIZ ─────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCircuitQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Accent bar stanga mov -->
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#FFD700"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏁"
                                android:textSize="26sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GHICEȘTE"
                                android:textColor="#E8E8F0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CIRCUITUL"
                                android:textColor="#FFD700"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="1dp"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Recunoaște circuitul după contur"
                                android:textColor="#7070A0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="26sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CARD: LIGHTS OUT REACTION ──────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardReactionGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#E10600"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚦"
                                android:textSize="26sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIGHTS OUT"
                                android:textColor="#E8E8F0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="REACTION TEST"
                                android:textColor="#E10600"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="1dp"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Testează-ți reflexele la startul cursei"
                                android:textColor="#7070A0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="26sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CARD: PIT STOP CHALLENGE ───────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPitStopGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#00D2BE"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔧"
                                android:textSize="26sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PIT STOP"
                                android:textColor="#E8E8F0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHALLENGE"
                                android:textColor="#00D2BE"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="1dp"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Schimbă anvelopele cât mai rapid"
                                android:textColor="#7070A0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="26sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CARD: STEERING CHALLENGE ───────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSteeringGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#3498DB"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏎️"
                                android:textSize="26sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Controlul Volanului"
                                android:textColor="#E8E8F0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHALLENGE"
                                android:textColor="#3498DB"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="1dp"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Înclină telefonul pentru a lua virajele"
                                android:textColor="#7070A0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="26sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>