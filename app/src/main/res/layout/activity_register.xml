<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810">

    <View
        android:id="@+id/speedLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_radial_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.18"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bara rosie sus -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/bg_speed_line"
            android:layout_marginBottom="18dp"/>

        <!-- LOGO F1 — identic cu Login -->
        <ImageView
            android:layout_width="125dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_f1_logo"
            android:contentDescription="F1 Logo"/>

        <!-- CONT NOU — subtitlu sub logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="C O N T   N O U"
            android:textColor="#60607A"
            android:textSize="11sp"
            android:letterSpacing="0.4"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"/>

        <!-- INTELLIGENCE HUB -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I N T E L L I G E N C E   H U B"
            android:textColor="#E10600"
            android:textSize="8sp"
            android:letterSpacing="0.3"
            android:layout_gravity="center"
            android:layout_marginBottom="14dp"/>

        <!-- Bara rosie jos -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/bg_speed_line"
            android:layout_marginBottom="36dp"/>

        <!-- LABEL EMAIL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADRESĂ EMAIL"
            android:textColor="#60607A"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="6dp"/>

        <!-- INPUT EMAIL -->
        <EditText
            android:id="@+id/etEmailRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="pilot@formula1.com"
            android:textColorHint="#30304A"
            android:textColor="#E8E8F0"
            android:textSize="13sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input_login"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="14dp"/>

        <!-- LABEL PAROLA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAROLĂ"
            android:textColor="#60607A"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="6dp"/>

        <!-- INPUT PAROLA -->
        <EditText
            android:id="@+id/etPasswordRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="••••••••"
            android:textColorHint="#30304A"
            android:textColor="#E8E8F0"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_input_login"
            android:inputType="textPassword"
            android:layout_marginBottom="28dp"/>

        <!-- BUTON REGISTER -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegister"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="CREEAZĂ CONT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.15"
            android:background="@drawable/bg_btn_primary"/>

        <!-- LINK LOGIN -->
        <TextView
            android:id="@+id/tvLoginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ai deja cont? Autentifică-te"
            android:textColor="#E10600"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>