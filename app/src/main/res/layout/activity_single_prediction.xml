<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810">

    <View
        android:id="@+id/speedLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/speedLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ── HEADER ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.AppCompat.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="← ÎNAPOI"
                    android:textColor="#7070A0"
                    android:textSize="11sp"
                    android:background="@drawable/bg_logout_btn"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SINGLE PILOT"
                    android:textColor="#E10600"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:shadowColor="#FF4D2E"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="8"/>

                <View android:layout_width="80dp" android:layout_height="38dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/bg_speed_line"
                android:layout_marginBottom="24dp"/>

            <!-- ── PILOT ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PILOT"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerPiloti"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_spinner_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"
                android:spinnerMode="dropdown"/>

            <!-- ── CIRCUIT ─────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CIRCUIT"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerCircuite"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_spinner_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"
                android:spinnerMode="dropdown"/>

            <!-- ── VREME + GRID ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VREME"
                        android:textColor="#60607A"
                        android:textSize="9sp"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerVreme"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_spinner_dark"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POZIȚIE GRILĂ"
                        android:textColor="#60607A"
                        android:textSize="9sp"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etStartingGrid"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="1-20"
                        android:inputType="number"
                        android:textColorHint="#30304A"
                        android:textColor="#E8E8F0"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_input_login"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── MOTOR AI ────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOTOR COMENTARIU AI"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupLLM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/radioOllama"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🤖 Ollama"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:checked="true"
                    android:background="@drawable/radio_llm_selector"
                    android:layout_marginEnd="6dp"/>

                <RadioButton
                    android:id="@+id/radioGemini"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="✨ Gemini"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:background="@drawable/radio_llm_selector"/>
            </RadioGroup>

            <!-- ── BUTON ANALIZEAZĂ ───────────────────────── -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAnalyze"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="⚡ ANALIZEAZĂ"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:background="@drawable/bg_btn_primary"
                android:layout_marginBottom="16dp"/>

            <!-- ── PROGRESS + LOADING TEXT ───────────────── -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="#E10600"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#60607A"
                android:textSize="12sp"
                android:textAlignment="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- ── RESULT CARD (arata dupa calcul) ────────── -->
            <LinearLayout
                android:id="@+id/layoutResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_result_card"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <!-- Pozitie + Pilot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Numarul pozitiei mare -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:id="@+id/tvPositionNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="#E10600"
                            android:textSize="52sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:shadowColor="#FF4D2E"
                            android:shadowDx="0"
                            android:shadowDy="0"
                            android:shadowRadius="16"/>

                        <TextView
                            android:id="@+id/tvPositionSuffix"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ST"
                            android:textColor="#E10600"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"
                            android:layout_marginStart="2dp"/>
                    </LinearLayout>

                    <!-- Separator vertical rosu -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="52dp"
                        android:background="#E10600"
                        android:layout_marginEnd="16dp"/>

                    <!-- Pilot + Meta -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvResultPilotName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PILOT"
                            android:textColor="#E8E8F0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvResultMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Circuit · Vreme · Grid"
                            android:textColor="#7070A0"
                            android:textSize="11sp"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E1E35"/>

                <!-- Scor model bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SCOR MODEL"
                        android:textColor="#60607A"
                        android:textSize="9sp"
                        android:letterSpacing="0.2"/>

                    <ProgressBar
                        android:id="@+id/progressScore"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:progressTint="#E10600"
                        android:progressBackgroundTint="#1E1E35"
                        android:max="100"
                        android:progress="70"/>

                    <TextView
                        android:id="@+id/tvScoreValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#E10600"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── BUTON COMENTARIU ───────────────────────── -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnShowCommentary"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🎙️  VEZI COMENTARIU SPORTIV"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:background="@drawable/bg_logout_btn"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>