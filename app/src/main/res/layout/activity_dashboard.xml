<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810">

    <View
        android:id="@+id/speedLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toBottomOf="@id/speedLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="F1 HUB"
            android:textColor="#E10600"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="#FF4D2E"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="LOGOUT"
            android:textColor="#7070A0"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_logout_btn"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BINE AI VENIT, PILOT"
        android:textColor="#7070A0"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MANAGEMENT PILOT"
                    android:textColor="#7070A0"
                    android:textSize="9sp"
                    android:letterSpacing="0.3"
                    android:layout_marginEnd="10dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1E1E35"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#E10600"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👤"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PROFIL PILOT &amp; STATISTICI"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Editează Driver Card · Clasament global"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnCommunity"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#00D2BE"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌍"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="COMUNITATEA F1"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cunoaște ceilalți piloți din grilă"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREDICȚII AI"
                    android:textColor="#7070A0"
                    android:textSize="9sp"
                    android:letterSpacing="0.3"
                    android:layout_marginEnd="10dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1E1E35"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSinglePilot"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#E10600"
                        android:layout_alignParentStart="true"/>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="40dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏎️"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SINGLE PILOT"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Predicție XGBoost pentru un pilot"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardFullRace"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#00D2BE"
                        android:layout_alignParentStart="true"/>
                    

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="40dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏁"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SIMULARE CURSĂ"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toți 20 de piloți + animație GIF"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANALIZĂ"
                    android:textColor="#7070A0"
                    android:textSize="9sp"
                    android:letterSpacing="0.3"
                    android:layout_marginEnd="10dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1E1E35"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardChampionship"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#FFD700"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏆"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAMPIONAT"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scenarii matematice la title"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDuel"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#9C27B0"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚔️"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PILOT VS PILOT"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telemetrie comparativă pe sectoare"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINIJOCURI"
                    android:textColor="#7070A0"
                    android:textSize="9sp"
                    android:letterSpacing="0.3"
                    android:layout_marginEnd="10dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1E1E35"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMiniGame"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#16162A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#FF9800"
                        android:layout_alignParentStart="true"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <LinearLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:gravity="center"
                            android:background="@drawable/bg_icon_container"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎮"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MINIJOCURI"
                                android:textColor="#E8E8F0"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start · Pit Stop · Volan"
                                android:textColor="#7070A0"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7070A0"
                            android:textSize="22sp"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>