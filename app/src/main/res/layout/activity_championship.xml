<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810">

    <View
        android:id="@+id/speedLine"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── HEADER FIX (nu scrolleaza) ───────────────────── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toBottomOf="@id/speedLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBack"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="wrap_content"
            android:layout_height="58dp"
            android:text="← ÎNAPOI"
            android:textColor="#7070A0"
            android:textSize="11sp"
            android:background="@drawable/bg_logout_btn"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CAMPIONAT"
            android:textColor="#E10600"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:shadowColor="#FF4D2E"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"/>

        <View android:layout_width="80dp" android:layout_height="38dp"/>
    </LinearLayout>

    <!-- ── DIVIDER ────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@drawable/bg_speed_line"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── CONTENT SCROLL ────────────────────────────────── -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ── TIP CAMPIONAT ──────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIP CAMPIONAT"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/radioDrivers"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🏎️  PILOȚI"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:checked="true"
                    android:background="@drawable/radio_llm_selector"
                    android:layout_marginEnd="6dp"/>

                <RadioButton
                    android:id="@+id/radioTeams"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🏭  ECHIPE"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:background="@drawable/radio_llm_selector"/>
            </RadioGroup>

            <!-- ── CURSE RAMASE ───────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURSE RĂMASE"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etRacesLeft"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_login"
                android:textColor="#E8E8F0"
                android:hint="Ex: 3"
                android:textColorHint="#30304A"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp"/>

            <!-- ── LISTA COMPETITORI ───────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="COMPETITORI"
                    android:textColor="#60607A"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddCompetitor"
                    style="@style/Widget.AppCompat.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="+ ADAUGĂ"
                    android:textColor="#E10600"
                    android:textSize="10sp"
                    android:background="@drawable/bg_logout_btn"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerCompetitors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_result_card"
                android:padding="12dp"
                android:layout_marginBottom="20dp"/>

            <!-- ── MOTOR AI ────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOTOR COMENTARIU AI"
                android:textColor="#60607A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioGroupLLM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/radioOllama"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🤖 Ollama"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:checked="true"
                    android:background="@drawable/radio_llm_selector"
                    android:layout_marginEnd="6dp"/>

                <RadioButton
                    android:id="@+id/radioGemini"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="✨ Gemini"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:button="@null"
                    android:gravity="center"
                    android:background="@drawable/radio_llm_selector"/>
            </RadioGroup>

            <!-- ── BUTON CALCUL ───────────────────────────── -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCalculate"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🏆 CALCULEAZĂ ȘANSELE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:background="@drawable/bg_btn_primary"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressChampionship"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="#E10600"
                android:layout_marginBottom="16dp"/>

            <!-- ── REZULTAT STATUS ────────────────────────── -->
            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#60607A"
                android:textSize="13sp"
                android:textAlignment="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- ── BUTOANE REZULTAT ───────────────────────── -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnShowCommentary"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🎙️  ANALIZĂ AI"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_logout_btn"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnShowMath"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🧮  CALCULE MATEMATICE"
                android:textColor="#E8E8F0"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_logout_btn"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>