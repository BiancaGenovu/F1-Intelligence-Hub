<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Stare selectata: fundal rosu F1 + border rosu -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#E10600"/>
            <corners android:radius="8dp"/>
            <stroke android:width="1dp" android:color="#E10600"/>
        </shape>
    </item>

    <!-- Stare neselectata: fundal inchis + border gri -->
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A"/>
            <corners android:radius="8dp"/>
            <stroke android:width="1dp" android:color="#444444"/>
        </shape>
    </item>

</selector>